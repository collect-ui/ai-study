.progress-box {
  width: 100%;
}

.progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  color: #414751;
  font-size: 24rpx;
  font-weight: 700;
}

.track {
  width: 100%;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eceef1;
}

.fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #005da7 0%, #67f7d5 100%);
}

.fill.green {
  background: #48ddbc;
}

.fill.gold {
  background: #ffb953;
}

.fill.red {
  background: #ba1a1a;
}
