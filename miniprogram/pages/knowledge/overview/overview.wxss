.knowledge-page {
  padding-bottom: 170rpx;
}

.knowledge-hero {
  position: relative;
  overflow: hidden;
  padding: 40rpx;
}

.knowledge-hero::after {
  content: "";
  position: absolute;
  top: -36rpx;
  right: -30rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 999rpx;
  background: rgba(0, 93, 167, 0.06);
}

.hero-label {
  color: #717783;
  font-size: 24rpx;
  font-weight: 800;
}

.hero-score {
  margin-top: 8rpx;
  color: #005da7;
  font-size: 70rpx;
  font-weight: 900;
}

.hero-score text {
  margin-left: 8rpx;
  font-size: 30rpx;
}

.beat-pill {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(103, 247, 213, 0.24);
  color: #006b58;
  font-size: 22rpx;
  font-weight: 800;
}

.ability-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
}

.ability-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 260rpx;
  padding: 28rpx;
  text-align: center;
}

.ability-card.wide {
  flex-direction: row;
  align-items: center;
  gap: 28rpx;
  grid-column: span 2;
  text-align: left;
}

.ability-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 144rpx;
  height: 144rpx;
  border-radius: 999rpx;
}

.ability-card.wide .ability-ring {
  flex: none;
  width: 168rpx;
  height: 168rpx;
}

.ability-ring view {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #005da7;
  font-size: 29rpx;
  font-weight: 900;
}

.ability-card.wide .ability-ring view {
  width: 122rpx;
  height: 122rpx;
}

.ability-card.green .ability-ring view {
  color: #006b58;
}

.ability-card.gold .ability-ring view {
  color: #7f5300;
}

.ability-copy {
  min-width: 0;
}

.ability-name {
  margin-top: 14rpx;
  color: #191c1e;
  font-size: 30rpx;
  font-weight: 900;
}

.ability-card.wide .ability-name {
  margin-top: 0;
}

.ability-desc {
  min-height: 58rpx;
  margin: 8rpx 0 20rpx;
  color: #717783;
  font-size: 22rpx;
  line-height: 30rpx;
}

.skills-title,
.insight-title {
  color: #191c1e;
  font-size: 32rpx;
  font-weight: 900;
}

.skill-row {
  margin-top: 28rpx;
}

.insight-card {
  padding: 32rpx;
  border: 1rpx solid rgba(0, 93, 167, 0.12);
  border-radius: 24rpx;
  background: rgba(212, 227, 255, 0.28);
}

.insight-title {
  color: #005da7;
}

.insight-line {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  color: #414751;
  font-size: 26rpx;
  line-height: 40rpx;
}

.insight-dot {
  flex: none;
  width: 10rpx;
  height: 10rpx;
  margin: 15rpx 18rpx 0 0;
  border-radius: 999rpx;
  background: #005da7;
}

.target-button {
  margin-top: 28rpx;
}

.map-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  border: 1rpx solid rgba(193, 199, 211, 0.5);
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(212, 227, 255, 0.35), rgba(255, 255, 255, 0.8));
  color: #717783;
  font-size: 24rpx;
  font-weight: 800;
}

.map-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 90rpx;
  height: 90rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: #d4e3ff;
  color: #005da7;
  font-size: 34rpx;
  font-weight: 900;
}
