.mistakes-page {
  padding-bottom: 260rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  text-align: center;
}

.stats-grid > view {
  border-right: 1rpx solid rgba(193, 199, 211, 0.45);
}

.stats-grid > view:last-child {
  border-right: 0;
}

.stats-value {
  font-size: 52rpx;
  font-weight: 900;
  line-height: 62rpx;
}

.stats-value.blue {
  color: #005da7;
}

.stats-value.gold {
  color: #7f5300;
}

.stats-value.green {
  color: #006b58;
}

.stats-label {
  margin-top: 6rpx;
  color: #717783;
  font-size: 22rpx;
  font-weight: 800;
}

.mastery-progress {
  margin-top: 34rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid rgba(193, 199, 211, 0.45);
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 70rpx;
  margin-right: 16rpx;
  padding: 0 34rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #414751;
  font-size: 24rpx;
  font-weight: 800;
}

.category-chip.active {
  background: #005da7;
  color: #ffffff;
}

.list-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.search-box {
  flex: none;
  display: flex;
  align-items: center;
  width: 270rpx;
  height: 70rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #f2f4f7;
}

.search-box text {
  margin-right: 8rpx;
  color: #717783;
  font-size: 28rpx;
}

.search-box input {
  flex: 1;
  min-width: 0;
  color: #191c1e;
  font-size: 24rpx;
}

.mistake-list {
  margin-top: 24rpx;
}

.empty-card {
  padding: 48rpx;
  color: #717783;
  font-size: 26rpx;
  text-align: center;
}

.mistake-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
}

.mistake-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #717783;
  font-size: 22rpx;
  font-weight: 700;
}

.mistake-title {
  margin-top: 20rpx;
  color: #191c1e;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 44rpx;
}

.mistake-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 14rpx;
  margin-top: 20rpx;
  color: #717783;
  font-size: 23rpx;
  font-weight: 700;
}

.tutor-note {
  color: #006b58;
}

.stars {
  color: #7f5300;
  letter-spacing: 2rpx;
}

.analysis-link {
  margin-left: auto;
  color: #005da7;
  font-weight: 900;
}

.analysis-box {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f2f4f7;
  color: #414751;
  font-size: 25rpx;
  line-height: 38rpx;
}

.review-button {
  position: fixed;
  left: 38rpx;
  right: 38rpx;
  bottom: 136rpx;
  z-index: 45;
}
