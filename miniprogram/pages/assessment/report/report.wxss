.report-page {
  padding-bottom: 70rpx;
}

.report-top-bar {
  display: flex;
  align-items: center;
  min-height: 72rpx;
}

.report-avatar {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #d4e3ff, #005da7);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
}

.report-title {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
  color: #005da7;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.report-bell {
  flex: none;
  width: 44rpx;
  height: 44rpx;
}

.score-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 46rpx 36rpx;
  text-align: center;
}

.score-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: conic-gradient(#005da7 0 85%, #e0e3e6 85% 100%);
}

.score-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 178rpx;
  height: 178rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.score-value {
  color: #005da7;
  font-size: 66rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.score-label {
  color: #717783;
  font-size: 22rpx;
  font-weight: 700;
}

.score-title {
  margin-top: 26rpx;
  color: #191c1e;
  font-size: 36rpx;
  font-weight: 900;
}

.beat-pill {
  margin-top: 16rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #67f7d5;
  color: #00705c;
  font-size: 24rpx;
  font-weight: 800;
}

.mastery-title,
.consult-title {
  color: #191c1e;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 42rpx;
}

.mastery-row {
  margin-top: 30rpx;
}

.field-block {
  margin-top: 28rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #717783;
  font-size: 24rpx;
  font-weight: 800;
}

.submit-button {
  margin-top: 32rpx;
}

.submit-button.done {
  background: #006b58;
}

.report-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.report-muted-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  border-radius: 22rpx;
  background: #e0e3e6;
  color: #414751;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}
