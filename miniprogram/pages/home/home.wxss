.prototype-page {
  position: relative;
  min-height: 2652rpx;
  box-sizing: border-box;
  padding: 34rpx 38rpx 170rpx;
  background: #f7f9fc;
  color: #191c1e;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 48rpx;
}

.brand {
  display: flex;
  align-items: center;
}

.brand-icon {
  width: 50rpx;
  height: 46rpx;
  margin-right: 18rpx;
}

.brand-title {
  color: #0060ac;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.bell-icon {
  width: 46rpx;
  height: 46rpx;
}

.login-card,
.assessment-card {
  box-sizing: border-box;
  width: 672rpx;
  border: 1rpx solid #e4e7ed;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 29, 61, 0.06);
}

.login-card {
  margin-top: 104rpx;
  padding: 48rpx 48rpx 47rpx;
}

.login-title {
  color: #191c1e;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 50rpx;
}

.input-field {
  box-sizing: border-box;
  display: block;
  height: 92rpx;
  margin-top: 52rpx;
  padding: 0 31rpx;
  border-radius: 22rpx;
  background: #f0f2f5;
  color: #191c1e;
  font-size: 29rpx;
  line-height: 92rpx;
}

.input-placeholder {
  color: #191c1e;
}

.code-row {
  display: flex;
  gap: 23rpx;
  margin-top: 33rpx;
}

.code-row .input-field {
  margin-top: 0;
}

.code-input {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
}

.code-button {
  width: 121rpx;
  height: 92rpx;
  border-radius: 22rpx;
  background: #d4e3ff;
  color: #0060ac;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.code-button.disabled {
  color: #6f89ad;
  background: #e3ebf9;
}

.login-button {
  height: 101rpx;
  margin-top: 30rpx;
  border-radius: 20rpx;
  background: #0068b7;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 101rpx;
  text-align: center;
}

.skip-link {
  margin-top: 36rpx;
  color: #717783;
  font-size: 25rpx;
  line-height: 34rpx;
  text-align: center;
  text-decoration: underline;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 67rpx;
}

.section-heading {
  color: #191c1e;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 52rpx;
}

.ai-pill {
  width: 174rpx;
  height: 45rpx;
  border-radius: 999rpx;
  background: #67f7d5;
  color: #00705c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 45rpx;
  text-align: center;
}

.assessment-card {
  margin-top: 30rpx;
  padding: 47rpx 47rpx 48rpx;
}

.field-label {
  color: #717783;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.stage-switch {
  display: flex;
  align-items: center;
  width: 576rpx;
  height: 83rpx;
  margin-top: 26rpx;
  border-radius: 22rpx;
  background: #f0f2f5;
  padding: 6rpx;
  box-sizing: border-box;
}

.stage-option {
  flex: 1;
  height: 71rpx;
  border-radius: 16rpx;
  color: #414751;
  font-size: 28rpx;
  line-height: 71rpx;
  text-align: center;
}

.stage-option.active {
  background: #ffffff;
  color: #0060ac;
  box-shadow: 0 3rpx 9rpx rgba(0, 29, 61, 0.06);
}

.grade-label {
  margin-top: 67rpx;
}

.grade-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx 25rpx;
  margin-top: 27rpx;
}

.grade-item {
  height: 78rpx;
  border: 2rpx solid #c1c7d3;
  border-radius: 22rpx;
  color: #414751;
  font-size: 28rpx;
  line-height: 78rpx;
  text-align: center;
}

.grade-item.selected {
  border-color: #0060ac;
  color: #0060ac;
}

.subject-label {
  margin-top: 64rpx;
}

.subject-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  column-gap: 31rpx;
  margin-top: 29rpx;
}

.subject-item {
  text-align: center;
}

.subject-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 122rpx;
  height: 122rpx;
  margin: 0 auto;
  border-radius: 25rpx;
  background: #f0f2f5;
}

.subject-icon image {
  width: 68rpx;
  height: 68rpx;
}

.selected-icon {
  border: 4rpx solid #0068b7;
  background: #d4e3ff;
  box-sizing: border-box;
}

.subject-name {
  margin-top: 18rpx;
  color: #414751;
  font-size: 25rpx;
  line-height: 34rpx;
}

.selected-name {
  color: #0060ac;
  font-weight: 800;
}

.tip-box {
  display: flex;
  align-items: center;
  width: 576rpx;
  height: 151rpx;
  margin-top: 67rpx;
  border: 1rpx solid #b8d8f4;
  border-radius: 16rpx;
  background: #edf8ff;
  box-sizing: border-box;
  padding: 0 31rpx;
}

.tip-icon {
  flex: none;
  width: 58rpx;
  height: 58rpx;
  margin-right: 20rpx;
}

.tip-text {
  color: #005da7;
  font-size: 27rpx;
  line-height: 41rpx;
}

.bottom-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 674rpx;
  height: 115rpx;
  margin-top: 250rpx;
  border-radius: 999rpx;
  background: #0068b7;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 800;
  box-shadow: 0 13rpx 24rpx rgba(0, 96, 172, 0.24);
}

.action-text {
  display: block;
  height: 44rpx;
  line-height: 44rpx;
}

.action-arrow {
  position: relative;
  flex: none;
  width: 34rpx;
  height: 34rpx;
  margin-left: 20rpx;
}

.action-arrow-line {
  position: absolute;
  left: 3rpx;
  top: 50%;
  width: 24rpx;
  height: 4rpx;
  margin-top: -2rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.action-arrow-head {
  position: absolute;
  right: 3rpx;
  top: 50%;
  width: 15rpx;
  height: 15rpx;
  margin-top: -8rpx;
  border-top: 4rpx solid #ffffff;
  border-right: 4rpx solid #ffffff;
  box-sizing: border-box;
  transform: rotate(45deg);
}
