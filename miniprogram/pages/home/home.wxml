<view class="prototype-page">
  <view class="top-bar">
    <view class="brand">
      <image class="brand-icon" src="{{assets.logo}}" mode="aspectFit" />
      <text class="brand-title">AI 学习助手</text>
    </view>
    <image class="bell-icon" src="{{assets.bell}}" mode="aspectFit" bindtap="showNotifications" />
  </view>

  <view class="login-card">
    <view class="login-title">欢迎回来</view>
    <input
      class="input-field"
      value="{{phone}}"
      type="number"
      maxlength="11"
      placeholder="请输入手机号"
      placeholder-class="input-placeholder"
      bindinput="handlePhoneInput"
    />
    <view class="code-row">
      <input
        class="input-field code-input"
        value="{{code}}"
        type="number"
        maxlength="6"
        placeholder="短信验证码"
        placeholder-class="input-placeholder"
        bindinput="handleCodeInput"
      />
      <view class="code-button {{canSendCode ? '' : 'disabled'}}" bindtap="sendCode">{{codeButtonText}}</view>
    </view>
    <view class="login-button" bindtap="login">登录</view>
    <view class="skip-link" bindtap="continueAsGuest">暂不登录，以游客身份继续</view>
  </view>

  <view class="section-head">
    <view class="section-heading">开始单次测评</view>
    <view class="ai-pill">AI 智能分析</view>
  </view>

  <view class="assessment-card">
    <view class="field-label">学段选择</view>
    <view class="stage-switch">
      <view
        class="stage-option {{item == selectedStage ? 'active' : ''}}"
        wx:for="{{stages}}"
        wx:key="*this"
        data-stage="{{item}}"
        bindtap="selectStage"
      >{{item}}</view>
    </view>

    <view class="field-label grade-label">年级</view>
    <view class="grade-grid">
      <view
        class="grade-item {{item == selectedGrade ? 'selected' : ''}}"
        wx:for="{{grades}}"
        wx:key="*this"
        data-grade="{{item}}"
        bindtap="selectGrade"
      >{{item}}</view>
    </view>

    <view class="field-label subject-label">测评科目</view>
    <view class="subject-grid">
      <view
        class="subject-item {{item.id == selectedSubject ? 'selected' : ''}}"
        wx:for="{{subjects}}"
        wx:key="id"
        data-subject="{{item.id}}"
        bindtap="selectSubject"
      >
        <view class="subject-icon {{item.id == selectedSubject ? 'selected-icon' : ''}}">
          <image src="{{item.icon}}" mode="aspectFit" />
        </view>
        <view class="subject-name {{item.id == selectedSubject ? 'selected-name' : ''}}">{{item.name}}</view>
      </view>
    </view>

    <view class="tip-box">
      <image class="tip-icon" src="{{assets.sparkle}}" mode="aspectFit" />
      <view class="tip-text">
        <view>基于当前年级进度，我们将为您准备</view>
        <view>15 道精选题目，预计耗时 20 分钟。</view>
      </view>
    </view>
  </view>

  <view class="bottom-action" bindtap="startAssessment">
    <text class="action-text">立即开始测评</text>
    <view class="action-arrow">
      <view class="action-arrow-line"></view>
      <view class="action-arrow-head"></view>
    </view>
  </view>
</view>
