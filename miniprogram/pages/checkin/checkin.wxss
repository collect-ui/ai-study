.checkin-page {
  padding-bottom: 48rpx;
}

.summary {
  padding: 40rpx;
  background: linear-gradient(135deg, #172033 0%, #315071 100%);
  color: #ffffff;
}

.summary-label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
}

.summary-value {
  margin-top: 16rpx;
  font-size: 72rpx;
  font-weight: 800;
}

.summary-text {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 28rpx;
  line-height: 1.6;
}

.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 24rpx;
}

.metric {
  padding: 28rpx;
}

.metric-value {
  font-size: 46rpx;
  font-weight: 800;
}

.metric-label {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.checkin-button {
  margin-top: 32rpx;
}

.reset-button {
  margin-top: 20rpx;
  color: #6b7280;
  background: transparent;
  font-size: 26rpx;
}
