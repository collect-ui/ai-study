collect_file_path=./collect/service_router.yml
system_model=my

driverName=mysql
dataSourceName=DB_USER:DB_PASSWORD@tcp(127.0.0.1:3306)/ai_study?charset=utf8mb4&parseTime=True&loc=Local
otherDataSource=

to_amis=false
schedule_enable=false
schedule_log=false
default_password=CHANGE_ME
can_cache=false
prevent_duplication=false

must_login=true
user_id_key=user_id
current_project_code=ai-study-admin
server_port=8026
is_https=false
domain=collect-ui.top

fileList=
local_file_dir=./file_data/files
file_prefix=/files
dirList=/data,./frontend/data,false;/files,./file_data/files,false;/collect-ui,./frontend/collect-ui,true
project=ai-study-admin
basic_auth_service=system.login
debug=true

# AI question import. Keep secret values out of source control; set real keys in the runtime config or environment.
question_ai_default_pdf_path=
question_ai_source_max_chars=120000
question_ai_chunk_chars=6000
question_ai_max_chunks=40
question_ai_cache_dir=./database/question_ai_cache
question_ai_deepseek_api_key=
question_ai_deepseek_base_url=https://api.deepseek.com
question_ai_deepseek_model=deepseek-chat
question_ai_codex_model=gpt-5.4-mini
question_ai_codex_chatgpt_model=gpt-5.5
